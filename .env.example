# Copia este archivo a `.env.local` y rellena los valores cuando conectemos cada pieza.
# Por ahora el core arranca sin ninguna de estas variables.

# --- Supabase (proyecto Axl-Projects; API keys modernas publishable/secret) ---
NEXT_PUBLIC_SUPABASE_URL=https://impscwgourdxhdejwkhe.supabase.co
# Publishable: segura para el cliente/browser, respeta RLS (empieza con sb_publishable_).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret: SOLO servidor, ignora RLS. Nunca la expongas al cliente (empieza con sb_secret_).
SUPABASE_SECRET_KEY=

# --- TikTok Display API (Login Kit) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Debe coincidir EXACTO con el Redirect URI registrado en el portal de TikTok.
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback

# --- Instagram Graph API (Instagram Login) ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# ID de la cuenta de Instagram (aparece bajo el @usuario en "Generar tokens").
INSTAGRAM_USER_ID=
# Token de acceso generado manualmente en el portal (larga duración, ~60 días).
# Para PRUEBAS: nos deja leer la API antes de tener el flujo OAuth completo.
INSTAGRAM_ACCESS_TOKEN=
