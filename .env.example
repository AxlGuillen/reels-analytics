# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://impscwgourdxhdejwkhe.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- TikTok Display API (Login Kit) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback

# --- Instagram Graph API (Instagram Login) ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- Cron ---
# Protege /api/cron/*. Vercel envía "Authorization: Bearer <CRON_SECRET>".
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# --- Digest semanal (Telegram) ---
# Crea el bot con @BotFather (te da el token). El chat id es el tuyo: escríbele
# al bot y consúltalo en https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Servidor MCP (/api/mcp) ---
# Token que los clientes MCP (Claude) mandan como "Authorization: Bearer ...".
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_SECRET=
